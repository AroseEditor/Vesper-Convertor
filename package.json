{
  "name": "Vesper-Convertor",
  "version": "2.00.0",
  "description": "Local-first file conversion. 50+ formats. Zero uploads. Zero limits.",
  "author": "Ayush.ue5",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/AroseEditor/Vesper-Convertor.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "7zip-bin": "^5.2.0",
    "archiver": "^6.0.0",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.4.0",
    "fast-xml-parser": "^4.3.0",
    "ffmpeg-static": "^5.2.0",
    "file-type": "^19.0.0",
    "fluent-ffmpeg": "^2.1.2",
    "js-yaml": "^4.1.0",
    "mammoth": "^1.6.0",
    "marked": "^18.0.4",
    "node-7z": "^3.0.0",
    "node-stream-zip": "^1.15.0",
    "obj2gltf": "^3.2.0",
    "opentype.js": "^1.3.4",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "png-to-ico": "^3.0.1",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^22.0.0",
    "sharp": "^0.33.0",
    "tesseract.js": "^5.0.0",
    "turndown": "^7.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "30.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.vesperconvertor.app",
    "publish": [
      {
        "provider": "github",
        "owner": "AroseEditor",
        "repo": "Vesper-Convertor"
      }
    ],
    "productName": "Vesper Convertor",
    "copyright": "Copyright © 2026 Ayush.ue5",
    "icon": "assets/icon.png",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/*.dll",
      "**/*.exe",
      "**/*.so",
      "**/*.so.*",
      "**/*.dylib"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "legalTrademarks": "Vesper Convertor by Ayush.ue5"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "runAfterFinish": false,
      "include": "build/installer.nsh",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "extraMetadata": {
      "author": "Ayush.ue5"
    }
  }
}
